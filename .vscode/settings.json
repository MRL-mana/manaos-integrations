{
  // Python設定
  "python.defaultInterpreterPath": "python",
  "python.analysis.typeCheckingMode": "basic",
  "python.analysis.autoImportCompletions": true,
  "python.analysis.completeFunctionParens": true,
  "python.linting.enabled": true,
  "python.linting.pylintEnabled": false,
  "python.linting.flake8Enabled": true,
  "python.formatting.provider": "black",
  "python.formatting.blackArgs": [
    "--line-length=100"
  ],
  "python.testing.pytestEnabled": true,
  "python.testing.unittestEnabled": false,

  // ファイルエンコーディング
  "files.encoding": "utf8",
  "files.autoGuessEncoding": true,
  "files.eol": "\n",

  // エディタ設定
  "editor.formatOnSave": true,
  "editor.codeActionsOnSave": {
    "source.organizeImports": "explicit"
  },
  "editor.rulers": [100],
  "editor.tabSize": 4,
  "editor.insertSpaces": true,
  "editor.detectIndentation": false,

  // ファイル除外設定
  "files.exclude": {
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/.pytest_cache": true,
    "**/.mypy_cache": true,
    "**/.venv": true,
    "**/venv": true,
    "**/ENV": true,
    "**/env": true,
    "**/node_modules": true,
    "**/.hf_cache": true,
    "**/.cache": true,
    "**/.brv": true
  },

  // 検索除外設定（AIが読まない・検索にヒットしない範囲を最大化）
  "search.exclude": {
    "**/__pycache__": true,
    "**/*.pyc": true,
    "**/.pytest_cache": true,
    "**/.mypy_cache": true,
    "**/node_modules": true,
    "**/.venv": true,
    "**/venv": true,
    "**/*.db": true,
    "**/*.log": true,
    // 大容量・低頻度アクセスディレクトリ
    "archive/**": true,
    "artifacts/**": true,
    "outputs/**": true,
    "output/**": true,
    "gallery_images/**": true,
    "generated_images/**": true,
    "ltx2_storage/**": true,
    "ollama_models/**": true,
    "sd-webui/**": true,
    "logs/**": true,
    "backups/**": true,
    "crash_snapshots/**": true,
    "phase1_runs/**": true,
    "moltbot_audit/**": true,
    "mem0_storage/**": true,
    "screenshots/**": true,
    "Reports/**": true,
    "data/**": true,
    ".hf_cache/**": true,
    ".cache/**": true,
    ".brv/**": true,
    // 実験・非アクティブ
    "experiments/**": true,
    "oh_my_opencode/**": true,
    "sara-ai/**": true,
    "free-assistant/**": true,
    "manaos-rpg/**": true,
    "rl_anything/**": true,
    "ltx2/**": true,
    "ltx2_mcp_server/**": true,
    "ltx2_workflows/**": true,
    "ltx2_templates/**": true
  },

  // PowerShell設定
  "powershell.enableProfileLoading": true,
  "powershell.scriptAnalysis.enable": true,
  "powershell.codeFormatting.preset": "OTBS",
  "powershell.codeFormatting.openBraceOnSameLine": false,
  "powershell.codeFormatting.newLineAfterOpenBrace": true,
  "powershell.codeFormatting.newLineAfterCloseBrace": true,
  "powershell.codeFormatting.whitespaceBeforeOpenBrace": true,
  "powershell.codeFormatting.whitespaceBeforeOpenParen": true,
  "powershell.codeFormatting.whitespaceAroundOperator": true,
  "powershell.codeFormatting.whitespaceAfterSeparator": true,
  "powershell.codeFormatting.whitespaceBetweenParameters": false,
  "powershell.codeFormatting.whitespaceInsideBrace": true,
  "powershell.codeFormatting.alignPropertyValuePairs": true,
  "powershell.codeFormatting.newLineAfterPipeline": true,

  // JSON設定
  "json.schemas": [
    {
      "fileMatch": ["**/config.json", "**/*_config.json"],
      "schema": {}
    }
  ],

  // Markdown設定
  "markdown.preview.fontSize": 14,
  "markdown.preview.lineHeight": 1.6,

  // ワークスペース設定（ファイル監視の除外 — ここが重さに直結）
  "files.watcherExclude": {
    "**/.git/objects/**": true,
    "**/.git/subtree-cache/**": true,
    "**/node_modules/**": true,
    "**/__pycache__/**": true,
    "**/*.db": true,
    "**/*.log": true,
    // 大容量ディレクトリを監視対象から完全除外
    "**/archive/**": true,
    "**/artifacts/**": true,
    "**/outputs/**": true,
    "**/output/**": true,
    "**/gallery_images/**": true,
    "**/generated_images/**": true,
    "**/ltx2_storage/**": true,
    "**/ollama_models/**": true,
    "**/sd-webui/**": true,
    "**/logs/**": true,
    "**/backups/**": true,
    "**/crash_snapshots/**": true,
    "**/phase1_runs/**": true,
    "**/moltbot_audit/**": true,
    "**/mem0_storage/**": true,
    "**/screenshots/**": true,
    "**/.hf_cache/**": true,
    "**/.cache/**": true,
    "**/.brv/**": true,
    "**/experiments/**": true,
    "**/sara-ai/**": true,
    "**/free-assistant/**": true,
    "**/manaos-rpg/**": true,
    "**/rl_anything/**": true,
    "**/ltx2/**": true
  },

  // ターミナル設定
  "terminal.integrated.defaultProfile.windows": "PowerShell",
  "terminal.integrated.profiles.windows": {
    "PowerShell": {
      "source": "PowerShell",
      "icon": "terminal-powershell"
    }
  },

  // その他
  "files.trimTrailingWhitespace": true,
  "files.insertFinalNewline": true,
  "files.trimFinalNewlines": true,

  // 問題パネルの除外設定
  "problems.exclude": {
    "**/node_modules/**": true,
    "**/__pycache__/**": true,
    "**/.pytest_cache/**": true,
    "**/.mypy_cache/**": true
  },

  // TypeScript/JavaScript設定
  "typescript.preferences.excludePackageJsonAutoImports": "on",
  "typescript.suggest.autoImports": true,
  "javascript.preferences.excludePackageJsonAutoImports": "on",
"javascript.suggest.autoImports": true,
"cursorpyright.analysis.autoImportCompletions": true,
"cursorpyright.analysis.typeCheckingMode": "basic",

  // Cursor Local LLM Auto Router
  "cursor.llm.customModels": [
    {
      "name": "auto-local",
      "provider": "openai-compatible",
      "baseUrl": "http://127.0.0.1:5211/v1",
      "apiKey": "local"
    }
  ],
  "cursor.llm.defaultModel": "auto-local"
}
