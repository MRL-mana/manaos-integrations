{
    "$schema": "http://json-schema.org/draft-07/schema#",
    "title": "ManaOS Autonomy Level Config",
    "description": "自律レベル L0〜L6 とゲート（Action Class・Confirm Token・予算・監査）の設定",
    "type": "object",
    "properties": {
        "autonomy_level": {
            "type": "integer",
            "minimum": 0,
            "maximum": 6,
            "default": 4,
            "description": "0=OFF, 1=Observe, 2=Notify, 3=Assist, 4=Act, 5=Autopilot, 6=Ops"
        },
        "allowed_action_classes": {
            "type": "array",
            "items": {
                "type": "string",
                "enum": [
                    "C0",
                    "C1",
                    "C2",
                    "C3",
                    "C4"
                ]
            },
            "description": "上書き用。未指定時は autonomy_level から自動"
        },
        "require_confirm_token_classes": {
            "type": "array",
            "items": {
                "type": "string",
                "enum": [
                    "C3",
                    "C4"
                ]
            },
            "default": [
                "C3",
                "C4"
            ],
            "description": "Confirm Token 必須の Action Class"
        },
        "confirm_tokens_allowlist": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "description": "許可する Confirm Token のリスト（オプション）"
        },
        "confirm_token_hmac_secret": {
            "type": "string",
            "description": "時間ベース HMAC Confirm Token 用の秘密鍵。設定時は verify で HMAC を検証"
        },
        "confirm_token_hmac_window_seconds": {
            "type": "integer",
            "default": 300,
            "description": "HMAC の時間窓（秒）。同一窓内で同じトークンが有効"
        },
        "budget": {
            "type": "object",
            "properties": {
                "per_hour": {
                    "type": "object",
                    "properties": {
                        "llm_calls": {
                            "type": "integer",
                            "minimum": -1
                        },
                        "image_jobs": {
                            "type": "integer",
                            "minimum": -1
                        },
                        "video_jobs": {
                            "type": "integer",
                            "minimum": -1
                        }
                    },
                    "description": "-1 は無制限"
                },
                "per_day": {
                    "type": "object",
                    "properties": {
                        "llm_calls": {
                            "type": "integer",
                            "minimum": -1
                        },
                        "image_jobs": {
                            "type": "integer",
                            "minimum": -1
                        },
                        "video_jobs": {
                            "type": "integer",
                            "minimum": -1
                        }
                    }
                }
            }
        },
        "quiet_hours": {
            "type": "object",
            "properties": {
                "start": {
                    "type": "string",
                    "pattern": "^[0-9]{2}:[0-9]{2}$"
                },
                "end": {
                    "type": "string",
                    "pattern": "^[0-9]{2}:[0-9]{2}$"
                }
            },
            "description": "通知を抑える時間帯（例: 22:00〜07:00）"
        },
        "degrade_policy": {
            "type": "object",
            "properties": {
                "on_budget_exceeded": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 6,
                    "default": 2
                },
                "on_repeated_failures": {
                    "type": "integer",
                    "minimum": 0,
                    "maximum": 6,
                    "default": 3
                },
                "on_repeated_failures_threshold": {
                    "type": "integer",
                    "minimum": 1,
                    "default": 5
                }
            }
        },
        "runbooks_enabled": {
            "type": "array",
            "items": {
                "type": "string"
            },
            "default": [
                "health_recover",
                "log_rotate",
                "inbox_scan"
            ],
            "description": "L4 で自動実行してよい Runbook ID"
        },
        "runbook_flags": {
            "type": "object",
            "description": "Runbook 内の復旧実行を許可するフラグ。safety.recovery_requires_runbook_flag と対応",
            "additionalProperties": {
                "type": "boolean"
            },
            "properties": {
                "health_recover_allow_restart": {
                    "type": "boolean",
                    "default": false
                },
                "pixel7_bridge_allow_restart": {
                    "type": "boolean",
                    "default": false
                }
            }
        },
        "audit_log_dir": {
            "type": "string",
            "default": ".",
            "description": "監査ログ JSONL を置くディレクトリ"
        },
        "budget_usage_dir": {
            "type": "string",
            "default": ".",
            "description": "予算使用量 JSON を置くディレクトリ"
        }
    }
}
