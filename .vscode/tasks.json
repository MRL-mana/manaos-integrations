{
  "version": "2.0.0",
  "inputs": [
    {
      "id": "manaosImagePrompt",
      "type": "promptString",
      "description": "画像生成プロンプト（英語推奨）",
      "default": "a beautiful landscape"
    }
  ],
  "tasks": [
    {
      "label": "ManaOS: Generate Image",
      "type": "shell",
      "command": "python",
      "args": ["scripts/generate_image_cli.py", "${input:manaosImagePrompt}"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true },
      "group": "none"
    },
    {
      "label": "ManaOS: Generate Image (Mufufu)",
      "type": "shell",
      "command": "python",
      "args": ["scripts/generate_image_cli.py", "--mufufu", "${input:manaosImagePrompt}"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true },
      "group": "none"
    },
    {
      "label": "ManaOS: Generate Image (Lab)",
      "type": "shell",
      "command": "python",
      "args": ["scripts/generate_image_cli.py", "--lab", "${input:manaosImagePrompt}"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true },
      "group": "none"
    },
    {
      "label": "ManaOS: Generate Image (JP→EN)",
      "type": "shell",
      "command": "python",
      "args": ["scripts/generate_image_cli.py", "--jp", "${input:manaosImagePrompt}"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true },
      "group": "none"
    },
    {
      "label": "ManaOS: RPG Tailscale 起動（スマホ/X280）",
      "type": "shell",
      "command": "pwsh",
      "args": ["-NoProfile", "-ExecutionPolicy", "Bypass", "-File", "${workspaceFolder}/start_manaos_rpg_tailscale.ps1"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true },
      "group": "none"
    },
    {
      "label": "ManaOS: 画像系 Tailscale 起動（9601/8188）",
      "type": "shell",
      "command": "pwsh",
      "args": ["-NoProfile", "-ExecutionPolicy", "Bypass", "-File", "${workspaceFolder}/start_image_services_tailscale.ps1"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true },
      "group": "none"
    },
    {
      "label": "ManaOS: 画像系 Tailscale 起動（管理者）",
      "type": "shell",
      "command": "cmd",
      "args": ["/c", "${workspaceFolder}/start_image_services_tailscale_admin.bat"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true },
      "group": "none"
    },
    {
      "label": "ManaOS: 公開状態チェック（RPG+画像系）",
      "type": "shell",
      "command": "pwsh",
      "args": ["-NoProfile", "-ExecutionPolicy", "Bypass", "-File", "${workspaceFolder}/check_tailscale_publish_status.ps1"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true },
      "group": "none"
    },
    {
      "label": "ManaOS: Tailscale フル起動（RPG+画像系+診断）",
      "type": "shell",
      "command": "pwsh",
      "args": ["-NoProfile", "-ExecutionPolicy", "Bypass", "-File", "${workspaceFolder}/start_tailscale_full_stack.ps1"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true },
      "group": "none"
    },
    {
      "label": "ManaOS: Tailscale フル起動（管理者）",
      "type": "shell",
      "command": "cmd",
      "args": ["/c", "${workspaceFolder}/start_tailscale_full_stack_admin.bat"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true },
      "group": "none"
    },
    {
      "label": "ManaOS: Tailscale 常時起動タスク登録（5分）",
      "type": "shell",
      "command": "pwsh",
      "args": ["-NoProfile", "-ExecutionPolicy", "Bypass", "-File", "${workspaceFolder}/install_tailscale_full_stack_keepalive_task.ps1", "-IntervalMinutes", "5", "-RunNow"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true },
      "group": "none"
    },
    {
      "label": "ManaOS: Tailscale 常時起動タスク状態確認",
      "type": "shell",
      "command": "pwsh",
      "args": ["-NoProfile", "-ExecutionPolicy", "Bypass", "-File", "${workspaceFolder}/status_tailscale_full_stack_keepalive_task.ps1"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true },
      "group": "none"
    },
    {
      "label": "ManaOS: Tailscale 常時起動タスク解除",
      "type": "shell",
      "command": "pwsh",
      "args": ["-NoProfile", "-ExecutionPolicy", "Bypass", "-File", "${workspaceFolder}/uninstall_tailscale_full_stack_keepalive_task.ps1"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true },
      "group": "none"
    }
  ]
}
