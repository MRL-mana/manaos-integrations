# ==================== ManaOS Docker Environment Variables ====================
# このファイルを .env にコピーして使用してください
# cp .env.template .env

# ==================== サービスポート設定 ====================
# Unified API
UNIFIED_API_PORT=9502

# MRL Memory Integration
MRL_MEMORY_PORT=9507

# Learning System
LEARNING_SYSTEM_PORT=9508

# LLM Routing
LLM_ROUTING_PORT=9509

# Gallery API
GALLERY_PORT=5559

# Video Pipeline
VIDEO_PIPELINE_PORT=9511

# ==================== API Keys ====================
# Brave Search API Key (optional)
BRAVE_API_KEY=

# CivitAI API Key (optional)
CIVITAI_API_KEY=

# OpenAI API Key (optional)
OPENAI_API_KEY=

# Anthropic API Key (optional)
ANTHROPIC_API_KEY=

# ==================== Monitoring ====================
# Grafana Admin Password
GRAFANA_PASSWORD=admin

# ==================== Database Settings ====================
# Memory Cache Settings
MEMORY_CACHE_MAX_SIZE=1000
MEMORY_CACHE_TTL=3600

# Learning System Database
LEARNING_DB_PATH=/app/data/learning.db

# ==================== Performance Settings ====================
# Worker processes
WORKER_PROCESSES=4

# Request timeout
REQUEST_TIMEOUT=30

# Max concurrent requests
MAX_CONCURRENT_REQUESTS=100

# ==================== Logging Settings ====================
LOG_LEVEL=INFO
LOG_FORMAT=json
LOG_FILE_MAX_SIZE=10485760
LOG_FILE_BACKUP_COUNT=5

# ==================== Distributed Deployment Settings ====================
# Remote service endpoints (Tailscale)
REMOTE_OLLAMA_URL=
REMOTE_COMFYUI_URL=
REMOTE_N8N_URL=
REMOTE_SEARXNG_URL=

# Enable distributed mode
DISTRIBUTED_MODE=false

# Device role (x280, konoha, cloud)
DEVICE_ROLE=standalone
