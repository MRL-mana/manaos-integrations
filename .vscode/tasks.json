      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true },
      "group": "none"
    },
    {
      "label": "ManaOS: Image Pipeline Health Check",
      "type": "shell",
      "command": "pwsh",
      "args": [
        "-NoProfile",
        "-ExecutionPolicy",
        "Bypass",
