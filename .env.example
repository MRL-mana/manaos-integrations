## ManaOS Integrations - 環境変数テンプレート
## このファイルを .env にコピーして値を設定してください:
##   cp .env.example .env

# ─── コアサービス ───────────────────────────────
# MRL Memory (3層メモリ)
MRL_MEMORY_API_KEY=your_mrl_memory_api_key_here
FWPKM_ENABLED=1
FWPKM_WRITE_MODE=full
FWPKM_WRITE_SAMPLE_RATE=1.0
FWPKM_WRITE_ENABLED=1
FWPKM_REVIEW_EFFECT=1

# 統合API認証
REQUIRE_AUTH=1
API_KEY=your_api_key_here
RATE_LIMIT_PER_MIN=60
MAX_INPUT_CHARS=200000
PII_MASK_ENABLED=1

# ─── Webhook ──────────────────────────────────
CURSOR_WEBHOOK_SECRET=change_me_to_a_strong_secret
CURSOR_WEBHOOK_PORT=9700
CURSOR_WEBHOOK_MAX_SKEW=300

# ─── LLM ──────────────────────────────────────
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_MODELS=D:\AI_Storage\Models\Ollama
# OPENROUTER_API_KEY=your_openrouter_key_here

# ─── ComfyUI ──────────────────────────────────
COMFYUI_PATH=C:\ComfyUI
COMFYUI_URL=http://127.0.0.1:8188
COMFYUI_MODELS_DIR=C:\ComfyUI/models/checkpoints
COMFYUI_OUTPUT_DIR=C:\ComfyUI/output

# ─── 外部 API ─────────────────────────────────
# GITHUB_TOKEN=ghp_xxxxxxxxxxxx
# CIVITAI_API_KEY=your_civitai_key_here
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx
# SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx

# ─── ギャラリー ────────────────────────────────
GALLERY_PORT=5559
GALLERY_IMAGES_DIR=gallery_images
MANAOS_IMAGE_DEFAULT_PROFILE=lab

# ─── MoltBot ──────────────────────────────────
MOLTBOT_GATEWAY_URL=http://127.0.0.1:8088
MOLTBOT_GATEWAY_SECRET=change_me

# ─── Windows Automation MCPサーバー ────────────
# WIN_AUTOMATION_MCP_HEALTH_PORT=5115

# ─── Pico HID MCPサーバー ─────────────────────
# PICO_HID_MCP_HEALTH_PORT=5116
# PICO_HID_USE_PICO=0  (1=Picoハードウェア使用, 0=pynputフォールバック)
# PICO_HID_USE_PC=1
