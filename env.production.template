# MRL Memory System - 本番環境設定テンプレート
# コピーして .env として使用してください

# ============================================
# セキュリティ設定（必須）
# ============================================

# 認証必須フラグ（本番では必ず1）
REQUIRE_AUTH=1

# APIキー（本番では強力なキーを設定）
API_KEY=your_secure_api_key_here

# レート制限（1分あたりのリクエスト数）
# まずは守り固める（60リクエスト/分）
RATE_LIMIT_PER_MIN=60

# 入力サイズ制限（文字数）
# 128K相当でも余裕、DoSも抑える
MAX_INPUT_CHARS=200000

# ============================================
# FWPKM設定
# ============================================

# FWPKM有効化
FWPKM_ENABLED=1

# 書き込みモード
# readonly: 読み取り専用（Phase 1）
# sampled: サンプリング書き込み（Phase 2: 10%）
# full: フル書き込み（Phase 3）
FWPKM_WRITE_MODE=readonly

# 書き込みサンプリング率（0.0-1.0）
# FWPKM_WRITE_MODE=sampled の場合に使用
FWPKM_WRITE_SAMPLE_RATE=0.1

# 書き込み有効化（Kill Switch）
# 0: 無効、1: 有効
FWPKM_WRITE_ENABLED=0

# 復習効果（Phase 4）
# 0: 無効、1: 有効
FWPKM_REVIEW_EFFECT=0

# ============================================
# サーバー設定
# ============================================

# ポート番号
PORT=5105

# デバッグモード（本番では必ずFalse）
DEBUG=False

# ============================================
# ログ設定
# ============================================

# ログレベル（INFO, WARNING, ERROR）
LOG_LEVEL=INFO
