meout_seconds"},"link":null},{"localized_name":"model","name":"model","shape":7,"type":"STRING","widget":{"name":"model"},"link":null},{"localized_name":"ip_address","name":"ip_address","shape":7,"type":"STRING","widget":{"name":"ip_address"},"link":null},{"localized_name":"port","name":"port","shape":7,"type":"INT","widget":{"name":"port"},"link":null}],"outputs":[{"localized_name":"Description","name":"Description","type":"STRING","links":[99]}],"properties":{"cnr_id":"comfyui-lmstudio-image-to-text-node","ver":"0d68cc36d111689919f9566397e2485e1bb5ed3d","Node name for S&R":"Expo Lmstudio Image To Text","ue_properties":{"widget_ue_connectable":{},"input_ue_unconnectable":{},"version":"7.5.2"}},"widgets_values":["Describe this image in detail","あなたは、フォトリアルなAI画像生成を専門とする、世界クラスのプロ写真家でありエキスパート・プロンプトエンジニアです。あなたのタスクは、ユーザーの入力や画像を分析し、極めて現実的で高品質な写真を生成するための詳細な英語プロンプトを作成することです。  絶対的なフォトリアリズムを実現するために、以下のガイドラインを厳守してください：  撮影スタイルの定義： 画像が「RAW photo」「8k UHD」であることを明記し、「DSLR camera」「Fujifilm XT5」などのプロ用機材、またはポートレート用の「85mm lens f/1.4」といった特定のレンズを指定してください。  照明と雰囲気： 現実的な照明条件を記述してください。「soft natural light」「golden hour」「cinematic lighting」「dramatic shadows」などの用語を使用し、奥行きとリアリズムを生み出します。  超リアルな詳細の強調： 質感を細かく記述する必要があります。「highly detailed skin texture」「visible pores」「individual hair strands」「realistic imperfections」、衣類の具体的な質感に言及してください。  写真の構図： 「shallow depth of field」「creamy bokeh background」「sharp focus on eyes」、自然でスナップ写真のようなポージング（candid posing）を取り入れてください。  出力形式： プロンプトは、キーワードの羅列ではなく、自然な英語による単一の流暢で詳細な説明文として提供してください。<u>内部的な思考プロセス、推論過程、および <think> タグなどのメタデータは一切出力に含めないでください。</u>  ネガティブな制約： 「illustration」「painting」「sketch」「3d render」「anime」「cartoon」などの非現実的な言葉は絶対に使用しないでください。<u>また、「Here is the prompt:」などの導入文や、解説、思考の痕跡も一切出力しないでください。</u>  <u>出力は、画像生成AIにそのまま入力できる「詳細な英語のプロンプト1段落」のみに限定してください。<think>ブロックや解説、返答の挨拶などは完全に排除し、結果だけを表示すること。</u>  プロンプトの冒頭には必ず以下のフレーズを含めてください： “An 18-year-old girl, a happy smile, a girl wearing cute earrings, round eyes, black bob-cut hair, a white hairband, and small moles under both eyes.”","qwen/qwen3-vl-4b","True",0,241158385415216,"randomize",2000,0.7,false,300,"","",0]},{"id":78,"type":"PrimitiveStringMultiline","pos":[135.72904042552494,-356.524924473509],"size":[400,200],"flags":{},"order":5,"mode":0,"inputs":[{"localized_name":"値","name":"value","type":"STRING","widget":{"name":"value"},"link":null}],"outputs":[{"localized_name":"文字列","name":"STRING","type":"STRING","links":[102]}],"title":"文字列（指示）","properties":{"cnr_id":"comfy-core","ver":"0.8.2","Node name for S&R":"PrimitiveStringMultiline"},"widgets_values":["You are an expert AI art prompter specialized in generating hyper-realistic photographs and portraits.\nYour task is to convert the user's request into a precise, comma-separated list of tags for a photorealistic AI model.\n\n[MANDATORY RULES]\n1.  **PREFIX**: Always start the prompt with these exact quality tags:\n    \"photorealistic, 8k, raw photo, sharp focus, detailed skin texture, detailed eyes, masterpiece, best quality,\"\n2.  **STYLE**: Enforce a \"realistic photo\" style. Describe lighting, shadows, and textures in detail.\n3.  **FORMAT**: Output ONLY tags separated by commas. No sentences.\n4.  **NEGATIVE**: Do NOT use terms like \"anime\", \"cartoon\", \"2d\", \"painting\", \"illustration\", \"sketch\".\n5.  **DETAIL**: Describe textures (skin pores, hair strands, fabric), realistic lighting (soft light, natural light), and camera effects (bokeh, depth of field).\n\n[OUTPUT EXAMPLE]\nphotorealistic, 8k, raw photo, sharp focus, detailed skin texture, detailed eyes, masterpiece, best quality, portrait of a young woman, platinum blonde hair, twin braids, iridescent makeup, blue eyes, close-up, soft studio lighting, looking at viewer, bokeh background"]},{"id":76,"type":"Expo Lmstudio Text Generation","pos":[2056.1242724939248,-159.2062234333615],"size":[270,370],"flags":{},"order":13,"mode":0,"inputs":[{"localized_name":"prompt","name":"prompt","type":"STRING","widget":{"name":"prompt"},"link":99},{"localized_name":"sys