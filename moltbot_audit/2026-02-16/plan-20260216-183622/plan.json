      "step_id": "scan_downloads",
      "action": "list_files",
      "params": {
        "path": "~/Downloads"
      },
      "condition": null,
      "rollback_hint": null
    },
    {
      "step_id": "classify",
      "action": "classify_files",
      "params": {
        "rules": [
          {
            "if_ext": [
              ".pdf"
            ],
            "move_to": "~/Documents/PDF"
          },
          {
            "if_ext": [
              ".png",
              ".jpg",
              ".webp"
            ],
            "move_to": "~/Pictures/Inbox"
          },
          {
            "if_ext": [
              ".zip"
            ],
            "move_to": "~/Downloads/Archives"
          }
        ],
        "dry_run": true
      },
      "condition": null,
      "rollback_hint": null
    },
    {
      "step_id": "apply_moves",
      "action": "move_files",
      "params": {
        "from_dry_run": true
      },
      "condition": null,
      "rollback_hint": null
    }
  ],
