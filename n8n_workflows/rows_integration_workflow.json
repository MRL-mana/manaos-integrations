    },
    {
      "parameters": {
        "operation": "postApi",
        "url": "=http://127.0.0.1:9502/api/rows/webhook",
        "sendBody": true,
        "bodyParameters": {
          "parameters": [
            {
              "name": "event_type",
              "value": "={{ $json.event_type }}"
            },
            {
              "name": "spreadsheet_id",
              "value": "={{ $json.spreadsheet_id }}"
            },
            {
              "name": "payload",
              "value": "={{ $json.payload }}"
            }
          ]
        },
        "options": {}
      },
      "id": "manaos-api",
      "name": "ManaOS API",
      "type": "n8n-nodes-base.httpRequest",
      "typeVersion": 3,
      "position": [450, 300]
    },
    {
      "parameters": {
        "operation": "query",
        "spreadsheetId": "={{ $json.spreadsheet_id }}",
        "query": "=この売上データ、傾向分析してグラフ出して",
        "options": {}
      },
      "id": "rows-ai-query",
      "name": "Rows AI分析",
      "type": "n8n-nodes-base.rows",
      "typeVersion": 1,
      "position": [650, 300],
      "credentials": {
        "rowsApi": {
          "id": "1",
          "name": "Rows API"
        }
      }
    },
    {
      "parameters": {
        "operation": "postMessage",
        "channel": "#manaos-notifications",
