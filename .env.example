## ManaOS Integrations - 環境変数テンプレート
## このファイルを .env にコピーして値を設定してください:
##   cp .env.example .env

# ================================================
# 🔐 API 認証設定
# ================================================
# APIキーの設定（カンマ区切りで複数指定可能）
# 生成方法: python -c "from api_auth import APIAuthManager; print(APIAuthManager().generate_api_key())"
MANAOS_API_KEYS=

# 開発環境 / 本番環境の切り替え
# development: デフォルトキー "dev_default_key_DO_NOT_USE_IN_PRODUCTION" が有効
# production: 明示的に設定されたキーのみ有効
MANAOS_ENV=development

# レート制限設定
RATE_LIMIT_ENABLED=true
RATE_LIMIT_REQUESTS=100  # リクエスト数
RATE_LIMIT_WINDOW=60     # 時間ウィンドウ（秒）

# ─── サービスポート設定 ─────────────────────────
# コアサービス
MRL_MEMORY_PORT=5105
LEARNING_SYSTEM_PORT=5126
LLM_ROUTING_PORT=5111
VIDEO_PIPELINE_PORT=5112
UNIFIED_API_PORT=9502

# MCPサーバー
PICO_HID_MCP_PORT=5136
WIN_AUTOMATION_MCP_PORT=5110

# インフラサービス
OLLAMA_PORT=11434
GALLERY_API_PORT=5559
COMFYUI_PORT=8188
MOLTBOT_GATEWAY_PORT=8088

# ─── ログ設定 ──────────────────────────────────
MANAOS_LOG_LEVEL=INFO
MANAOS_LOG_DIR=logs
MANAOS_LOG_JSON=0
LOG_MAX_FILE_SIZE_MB=50
LOG_BACKUP_COUNT=5
LOG_RETENTION_DAYS=30

# ─── モニタリング設定 ──────────────────────────
PROMETHEUS_ENABLED=0
PROMETHEUS_PORT=9090
METRICS_ENABLED=1

# ─── コアサービス ───────────────────────────────
# MRL Memory (3層メモリ)
MRL_MEMORY_API_KEY=your_mrl_memory_api_key_here
FWPKM_ENABLED=1
FWPKM_WRITE_MODE=full
FWPKM_WRITE_SAMPLE_RATE=1.0
FWPKM_WRITE_ENABLED=1
FWPKM_REVIEW_EFFECT=1

# Learning System (学習システム)
LEARNING_ENABLED=1
LEARNING_AUTO_OPTIMIZE=1

# LLM Routing (LLMルーティング)
LLM_ROUTING_ENABLED=1
LLM_FALLBACK_MODEL=qwen2.5:7b
LLM_RETRY_ATTEMPTS=3

# ─── 統合API認証 ───────────────────────────────
REQUIRE_AUTH=1
API_KEY=your_api_key_here
RATE_LIMIT_PER_MIN=60
MAX_INPUT_CHARS=200000
PII_MASK_ENABLED=1

# ─── Webhook ──────────────────────────────────
CURSOR_WEBHOOK_SECRET=change_me_to_a_strong_secret
CURSOR_WEBHOOK_PORT=9700
CURSOR_WEBHOOK_MAX_SKEW=300

# ─── LLM ──────────────────────────────────────
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_MODELS=D:\AI_Storage\Models\Ollama
# OPENROUTER_API_KEY=your_openrouter_key_here

# ─── ComfyUI ──────────────────────────────────
COMFYUI_PATH=C:\ComfyUI
COMFYUI_URL=http://127.0.0.1:8188
COMFYUI_MODELS_DIR=C:\ComfyUI/models/checkpoints
COMFYUI_OUTPUT_DIR=C:\ComfyUI/output
COMFYUI_ENABLED=0

# ─── 外部 API ─────────────────────────────────
# GITHUB_TOKEN=ghp_xxxxxxxxxxxx
# CIVITAI_API_KEY=your_civitai_key_here
# SLACK_WEBHOOK_URL=https://hooks.slack.com/services/xxx/xxx/xxx
# SLACK_BOT_TOKEN=xoxb-xxxxxxxxxxxx

# ─── ギャラリー ────────────────────────────────
GALLERY_PORT=5559
GALLERY_IMAGES_DIR=gallery_images
MANAOS_IMAGE_DEFAULT_PROFILE=lab

# ─── MoltBot ──────────────────────────────────
MOLTBOT_GATEWAY_URL=http://127.0.0.1:8088
MOLTBOT_GATEWAY_SECRET=change_me

# ─── Pico HID MCPサーバー ─────────────────────
PICO_HID_MCP_ENABLED=1
PICO_HID_USE_PICO=0
PICO_HID_USE_PC=1

# ─── Windows Automation MCPサーバー ────────────
WIN_AUTOMATION_MCP_ENABLED=1

# ─── パフォーマンス最適化 ───────────────────────
ENABLE_CACHE=1
CACHE_TTL_SECONDS=3600
MAX_WORKERS=4
REQUEST_TIMEOUT_SECONDS=30
