er_prompt","type":"STRING","widget":{"name":"user_prompt"},"link":null},{"localized_name":"system_prompt","name":"system_prompt","type":"STRING","widget":{"name":"system_prompt"},"link":26},{"localized_name":"model_key","name":"model_key","type":"STRING","widget":{"name":"model_key"},"link":null},{"localized_name":"auto_unload","name":"auto_unload","type":"COMBO","widget":{"name":"auto_unload"},"link":null},{"localized_name":"unload_delay","name":"unload_delay","type":"INT","widget":{"name":"unload_delay"},"link":null},{"localized_name":"seed","name":"seed","type":"INT","widget":{"name":"seed"},"link":null},{"localized_name":"max_tokens","name":"max_tokens","shape":7,"type":"INT","widget":{"name":"max_tokens"},"link":null},{"localized_name":"temperature","name":"temperature","shape":7,"type":"FLOAT","widget":{"name":"temperature"},"link":null},{"localized_name":"debug","name":"debug","shape":7,"type":"BOOLEAN","widget":{"name":"debug"},"link":null},{"localized_name":"timeout_seconds","name":"timeout_seconds","shape":7,"type":"INT","widget":{"name":"timeout_seconds"},"link":null},{"localized_name":"model","name":"model","shape":7,"type":"STRING","widget":{"name":"model"},"link":null},{"localized_name":"ip_address","name":"ip_address","shape":7,"type":"STRING","widget":{"name":"ip_address"},"link":null},{"localized_name":"port","name":"port","shape":7,"type":"INT","widget":{"name":"port"},"link":null}],"outputs":[{"localized_name":"Description","name":"Description","type":"STRING","links":[49]}],"properties":{"cnr_id":"comfyui-lmstudio-image-to-text-node","ver":"0d68cc36d111689919f9566397e2485e1bb5ed3d","Node name for S&R":"Expo Lmstudio Image To Text","ue_properties":{"widget_ue_connectable":{},"input_ue_unconnectable":{},"version":"7.5.2"}},"widgets_values":["Describe this image in detail","あなたは、フォトリアルなAI画像生成を専門とする、世界クラスのプロ写真家でありエキスパート・プロンプトエンジニアです。あなたのタスクは、ユーザーの入力や画像を分析し、極めて現実的で高品質な写真を生成するための詳細な英語プロンプトを作成することです。  絶対的なフォトリアリズムを実現するために、以下のガイドラインを厳守してください：  撮影スタイルの定義： 画像が「RAW photo」「8k UHD」であることを明記し、「DSLR camera」「Fujifilm XT5」などのプロ用機材、またはポートレート用の「85mm lens f/1.4」といった特定のレンズを指定してください。  照明と雰囲気： 現実的な照明条件を記述してください。「soft natural light」「golden hour」「cinematic lighting」「dramatic shadows」などの用語を使用し、奥行きとリアリズムを生み出します。  超リアルな詳細の強調： 質感を細かく記述する必要があります。「highly detailed skin texture」「visible pores」「individual hair strands」「realistic imperfections」、衣類の具体的な質感に言及してください。  写真の構図： 「shallow depth of field」「creamy bokeh background」「sharp focus on eyes」、自然でスナップ写真のようなポージング（candid posing）を取り入れてください。  出力形式： プロンプトは、キーワードの羅列ではなく、自然な英語による単一の流暢で詳細な説明文として提供してください。<u>内部的な思考プロセス、推論過程、および <think> タグなどのメタデータは一切出力に含めないでください。</u>  ネガティブな制約： 「illustration」「painting」「sketch」「3d render」「anime」「cartoon」などの非現実的な言葉は絶対に使用しないでください。<u>また、「Here is the prompt:」などの導入文や、解説、思考の痕跡も一切出力しないでください。</u>  <u>出力は、画像生成AIにそのまま入力できる「詳細な英語のプロンプト1段落」のみに限定してください。<think>ブロックや解説、返答の挨拶などは完全に排除し、結果だけを表示すること。</u>  プロンプトの冒頭には必ず以下のフレーズを含めてください： “An 18-year-old girl, a happy smile, a girl wearing cute earrings, round eyes, black bob-cut hair, a white hairband, and small moles under both eyes.”","qwen/qwen3-vl-4b","True",0,550560598100545,"randomize",2000,0.7,false,300,"","",0]},{"id":38,"type":"PrimitiveStringMultiline","pos":[1068.2577153499326,750.0078135450467],"size":[400,200],"flags":{},"order":8,"mode":0,"inputs":[{"localized_name":"値","name":"value","type":"STRING","widget":{"name":"value"},"link":null}],"outputs":[{"localized_name":"文字列","name":"STRING","type":"STRING","links":[48]}],"title":"文字列（指示）system prompt","properties":{"cnr_id":"comfy-core","ver":"0.8.2","Node name for S&R":"PrimitiveStringMultiline"},"widgets_values":["アニメイラスト用推奨設定（システムプロンプト）\nあなたは世界最高峰のアニメーターであり、プロンプトエンジニアです。入力されたキャラクターやシーンの情報を、極めて詳細で洗練された「アニメイラスト（2D）」の記述に変換してください。\n\n以下のルールを厳守してください：\n\n人物描写の具体化: アニメ的な美学に基づいた描写を行う。滑らかな肌（smooth skin）、繊細な顔立ち（refined facial features）、瞳のハイライト（sparkling eyes, intricate iris detail）、そして「定義された髪の束感（well-defined hair strands）」を詳細に記述する。\n\n構図の多様性: 同一の構図を避け、\"Dynamic anime angle\", \"Dutch angle\", \"Full-body shot\", \"Looking over the shoulder\" など、躍動感のある視点とポーズを積極的に提案すること。\n\n描画スタイルと質感: 清潔感のある線画（clean lineart）と、プロのアニメ制作のような色使い（vibrant colors, cel shading, soft gradients）を指定する。\n\n照明（ライティング）: アニメ特有の光の表現（Cinematic anime lighting, bloom effect, rim light, lens flare）や、ドラマチックな影のコントラスト（dramatic shadows）を記述する。\n\n禁止ワード: \"Real human\", \"Photorealistic\", \"RAW photo\", \"Skin pores\" などの実写系単語を避け、代わりに \"Masterpiece anime illustration\", \"High-quality 2D digital art\", \"High-res cel shaded style\" を使用する。\n\n出力形式: 生成されるテキストは、画像生成AIが直接読み取れる英語のプロンプトのみを出力し、余計な解説は省くこと。\n\nOutput ONLY the detailed, descriptive English paragraph."]},{"id":37,"type":"Expo Lmstudio Text Generation","pos":[764.1823016200048,651.7897798343563],"size":[270,370],"flags":{},"order":17,"mode":0,"inputs":[{"localized_name":"prompt","name":"prompt","type":"STRING","widget":{"name":"prompt"},"link":47},{"localized_name":"system_prompt","name":"system_prompt","type":"STRING","widget":{"name":"system_prompt"},"link":48},{"localized_name":"model_key","name":"model_key","type":"STRING","widget":{"name":"model_key"},"link":null},{"localized_name":"auto_unload","name":"auto_unload","type":"COMBO","widget":{"name":"auto_unload"},"link":null},{"localized_name":"unload_delay","name":"unload_delay","type":"INT","widget":{"name":"unload_delay"},"link":null},{"localized_name":"seed","name":"seed","type":"INT","widget":{"name":"seed"},"link":null},{"localized_name":"max_tokens","name":"max_tokens","shape":7,"type":"INT","widget":{"name":"max_tokens"},"link":null},{"localized_name":"temperature","name":"temperature","shape":7,"type":"FLOAT","widget":{"name":"temperature"},"link":null},{"localized_name":"debug","name":"debug","shape":7,"type":"BOOLEAN","widget":{"name":"debug"},"link":null},{"localized_name":"timeout_seconds","name":"timeout_seconds","shape":7,"type":"INT","widget":{"name":"timeout_seconds"},"link":null},{"localized_name":"model","name":"model","shape":7,"type":"STRING","widget":{"name":"mo