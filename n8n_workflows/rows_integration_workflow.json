        "options": {}
      },
      "id": "slack-notify",
      "name": "Slack通知",
      "type": "n8n-nodes-base.slack",
      "typeVersion": 1,
      "position": [850, 300],
      "credentials": {
        "slackApi": {
          "id": "2",
          "name": "Slack API"
        }
      }
    },
    {
      "parameters": {
        "operation": "create",
        "name": "=Rows分析_{{ $now.toISO() }}.md",
        "content": "=# Rowsデータ分析\n\n- スプレッドシートID: {{ $json.spreadsheet_id }}\n- 分析日時: {{ $now.toISO() }}\n- 分析結果: {{ $json.result }}\n\n## 要約\n\n{{ $json.summary }}",
        "options": {}
