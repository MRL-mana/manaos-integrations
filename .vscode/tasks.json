{
  "version": "2.0.0",
  "inputs": [
    {
      "id": "manaosImagePrompt",
      "type": "promptString",
      "description": "画像生成プロンプト（英語推奨）",
      "default": "a beautiful landscape"
    }
  ],
  "tasks": [
    {
      "label": "ManaOS: Generate Image",
      "type": "shell",
      "command": "python",
      "args": ["scripts/generate_image_cli.py", "${input:manaosImagePrompt}"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true },
      "group": "none"
    },
    {
      "label": "ManaOS: Generate Image (Mufufu)",
      "type": "shell",
      "command": "python",
      "args": ["scripts/generate_image_cli.py", "--mufufu", "${input:manaosImagePrompt}"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true },
      "group": "none"
    },
    {
      "label": "ManaOS: Generate Image (Lab)",
      "type": "shell",
      "command": "python",
      "args": ["scripts/generate_image_cli.py", "--lab", "${input:manaosImagePrompt}"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true },
      "group": "none"
    },
    {
      "label": "ManaOS: Generate Image (JP→EN)",
      "type": "shell",
      "command": "python",
      "args": ["scripts/generate_image_cli.py", "--jp", "${input:manaosImagePrompt}"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true },
      "group": "none"
    },
    {
      "label": "ManaOS: policy --list",
      "type": "shell",
      "command": "python",
      "args": ["${workspaceFolder}/tools/manaosctl.py", "policy", "--list"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "ManaOS: policy --check",
      "type": "shell",
      "command": "python",
      "args": ["${workspaceFolder}/tools/manaosctl.py", "policy", "--check"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "ManaOS: Control Panel 起動 (port 9800)",
      "type": "shell",
      "command": "python",
      "args": ["${workspaceFolder}/scripts/misc/manaos_dashboard_server.py"],
      "isBackground": true,
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "dedicated" }
    },
    {
      "label": "ManaOS: Control Panel を開く (ブラウザ)",
      "type": "shell",
      "command": "Start-Process",
      "args": ["http://127.0.0.1:9800/"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "silent", "panel": "shared" }
    },
    {
      "label": "ManaOS: daily report (stdout)",
      "type": "shell",
      "command": "python",
      "args": ["${workspaceFolder}/scripts/misc/manaos_daily_report.py", "--stdout"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared" }
    },

    // ─── manaosctl 運用タスク群 ──────────────────────────────
    {
      "label": "ManaOS: ① status（全サービス状態）",
      "type": "shell",
      "command": "python",
      "args": ["tools/manaosctl.py", "status"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true }
    },
    {
      "label": "ManaOS: ② up（Tier0+1 起動）",
      "type": "shell",
      "command": "python",
      "args": ["tools/manaosctl.py", "up"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true }
    },
    {
      "label": "ManaOS: ③ heal（DOWNを自動復旧）",
      "type": "shell",
      "command": "python",
      "args": ["tools/manaosctl.py", "heal"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true }
    },
    {
      "label": "ManaOS: ④ deps --order（起動順序確認）",
      "type": "shell",
      "command": "python",
      "args": ["tools/manaosctl.py", "deps", "--order"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true }
    },
    {
      "label": "ManaOS: ⑤ events（直近イベント30件）",
      "type": "shell",
      "command": "python",
      "args": ["tools/manaosctl.py", "events"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true }
    },
    {
      "label": "ManaOS: ⑥ analyze（LLMでイベント分析）",
      "type": "shell",
      "command": "python",
      "args": ["tools/manaosctl.py", "analyze"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true }
    },
    {
      "label": "ManaOS: ⑦ tier（Tier別サービス一覧）",
      "type": "shell",
      "command": "python",
      "args": ["tools/manaosctl.py", "tier"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true }
    },
    {
      "label": "ManaOS: heal --dry-run（復旧プレビュー）",
      "type": "shell",
      "command": "python",
      "args": ["tools/manaosctl.py", "heal", "--dry-run"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true }
    },
    {
      "label": "ManaOS: deps（全依存一覧）",
      "type": "shell",
      "command": "python",
      "args": ["tools/manaosctl.py", "deps"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true }
    },
    {
      "label": "ManaOS: deps --tree（blast-radius ツリー）",
      "type": "shell",
      "command": "python",
      "args": ["tools/manaosctl.py", "deps", "--tree"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true }
    },
    {
      "label": "ManaOS: watch --once（監視1回実行）",
      "type": "shell",
      "command": "python",
      "args": ["tools/manaosctl.py", "watch", "--once"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true }
    },
    {
      "label": "ManaOS: watch（60秒間隔 監視ループ）",
      "type": "shell",
      "command": "python",
      "args": ["tools/manaosctl.py", "watch"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true }
    },
    // ── GTD ──────────────────────────────────────────────────────────────────
    {
      "label": "shell: ManaOS: GTD Morning（今日の日次ログ作成）",
      "type": "shell",
      "command": "python",
      "args": ["tools/manaosctl.py", "gtd", "morning"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true }
    },
    {
      "label": "shell: ManaOS: GTD Inbox一覧（件数確認）",
      "type": "shell",
      "command": "python",
      "args": ["tools/manaosctl.py", "gtd", "inbox"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true }
    },
    {
      "label": "shell: ManaOS: GTD Morning タスク登録（毎朝07:00）",
      "type": "shell",
      "command": "schtasks",
      "args": [
        "/Create", "/TN", "ManaOS_GTD_Morning", "/SC", "DAILY", "/ST", "07:00",
        "/TR",
        "cmd /c \"cd /d ${workspaceFolder} && python tools/manaosctl.py gtd morning >> logs/gtd_morning.log 2>&1\"",
        "/F"
      ],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true }
    },
    {
      "label": "shell: ManaOS: GTD Morning タスク解除",
      "type": "shell",
      "command": "schtasks",
      "args": ["/Delete", "/TN", "ManaOS_GTD_Morning", "/F"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true }
    },
    {
      "label": "shell: ManaOS: GTD Capture Server 起動（port 5130）",
      "type": "shell",
      "command": "python",
      "args": ["gtd_capture_server.py"],
      "options": { "cwd": "${workspaceFolder}" },
      "isBackground": true,
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "dedicated", "echo": true }
    },
    {
      "label": "shell: ManaOS: GTD Capture Server 停止",
      "type": "shell",
      "command": "powershell",
      "args": ["-Command", "Get-NetTCPConnection -LocalPort 5130 -State Listen -ErrorAction SilentlyContinue | ForEach-Object { Stop-Process -Id (Get-Process -Id (Get-NetTCPConnection -LocalPort 5130 -State Listen).OwningProcess).Id -Force }; Write-Host 'GTD Capture Server 停止完了 (port 5130)'"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true }
    },
    {
      "label": "shell: ManaOS: GTD Capture ヘルスチェック",
      "type": "shell",
      "command": "powershell",
      "args": ["-Command", "try { $r = Invoke-RestMethod http://127.0.0.1:5130/health; Write-Host \"UP: $($r | ConvertTo-Json -Compress)\" } catch { Write-Host 'DOWN: GTD Capture Server は起動していません' }"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true }
    },
    {
      "label": "shell: ManaOS: GTD Pixel7 Shortcuts インポートファイルを開く",
      "type": "shell",
      "command": "start",
      "args": ["http://127.0.0.1:5130/import/shortcuts"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true }
    },
    {
      "label": "shell: ManaOS: GTD Pixel7 ショートカット インポート実行",
      "type": "shell",
      "command": "powershell",
      "args": ["-Command", "Invoke-WebRequest http://127.0.0.1:5130/download/gtd-shortcuts -OutFile $env:TEMP\\gtd_pixel7_shortcuts.json; Write-Host \"保存先: $env:TEMP\\gtd_pixel7_shortcuts.json\""],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true }
    },
    {
      "label": "shell: ManaOS: GTD Next Actions一覧",
      "type": "shell",
      "command": "python",
      "args": ["tools/manaosctl.py", "gtd", "next"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true }
    },
    {
      "label": "shell: ManaOS: GTD Process（Inbox振り分け）",
      "type": "shell",
      "command": "python",
      "args": ["tools/manaosctl.py", "gtd", "process"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "dedicated", "echo": true, "focus": true }
    },
    {
      "label": "shell: ManaOS: GTD Weekly Review",
      "type": "shell",
      "command": "python",
      "args": ["tools/manaosctl.py", "gtd", "weekly"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true }
    }
  ]
}
