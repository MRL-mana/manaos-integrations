            "headers": {
                "Content-Type": "application/json"
            },
            "parameters": {
                "content": {
                    "type": "string",
                    "description": "保存する内容",
                    "required": true
                },
                "format_type": {
                    "type": "string",
                    "description": "フォーマットタイプ（conversation/memo/research/system/auto）",
                    "default": "auto"
                }
            }
        },
        {
            "name": "memory_recall",
