{
    "_comment_ask_orchestrator": "1ツールだけ使う場合は ask_orchestrator のみ有効にすると、オーケストレータ中心設計になる（docs/guides/ORCHESTRATOR_AI_TOOL_DESIGN.md）",
    "tools": [
        {
            "name": "ask_orchestrator",
            "description": "室温・湿度・天気・照明操作など、ローカル環境に関する情報取得や操作を行う。自然文で投げる汎用オーケストレーター。一般的な知識や検索はこのツールを使わず検索で対応する。",
            "url": "http://127.0.0.1:5106/api/execute",
            "method": "POST",
            "headers": {
                "Content-Type": "application/json"
            },
            "parameters": {
                "query": {
                    "type": "string",
                    "description": "自然文でのリクエスト内容",
                    "required": true
                }
            }
        },
        {
            "name": "memory_store",
            "description": "記憶に情報を保存します（レスポンスに _meta.trim_policy が含まれます）",
            "url": "http://127.0.0.1:9502/api/memory/store",
            "method": "POST",
            "headers": {
                "Content-Type": "application/json"
            },
            "parameters": {
                "content": {
                    "type": "string",
                    "description": "保存する内容",
                    "required": true
                },
                "format_type": {
                    "type": "string",
                    "description": "フォーマットタイプ（conversation/memo/research/system/auto）",
                    "default": "auto"
                }
            }
        },
        {
            "name": "mana_memory_write",
            "description": "Blueprint互換: 記憶へ書き込み（type/text/tags/source/time）。レスポンスに _meta.trim_policy が含まれます。",
            "url": "http://127.0.0.1:9502/memory/write",
            "method": "POST",
            "headers": {
                "Content-Type": "application/json"
            },
            "parameters": {
                "type": {
                    "type": "string",
                    "description": "記憶タイプ（note/decision/task/log など）",
                    "default": "memo"
                },
                "text": {
                    "type": "string",
                    "description": "保存する本文",
                    "required": true
                },
                "tags": {
                    "type": "array",
                    "description": "タグ配列"
                },
                "source": {
                    "type": "string",
                    "description": "情報源"
                },
                "time": {
                    "type": "string",
                    "description": "時刻（ISO8601推奨）"
                }
            }
        },
