{
  "version": "2.0.0",
  "inputs": [
    {
      "id": "manaosImagePrompt",
      "type": "promptString",
      "description": "画像生成プロンプト（英語推奨）",
      "default": "a beautiful landscape"
    }
  ],
  "tasks": [
    {
      "label": "ManaOS: Generate Image",
      "type": "shell",
      "command": "python",
      "args": ["scripts/generate_image_cli.py", "${input:manaosImagePrompt}"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true },
      "group": "none"
    },
    {
      "label": "ManaOS: Generate Image (Mufufu)",
      "type": "shell",
      "command": "python",
      "args": ["scripts/generate_image_cli.py", "--mufufu", "${input:manaosImagePrompt}"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true },
      "group": "none"
    },
    {
      "label": "ManaOS: Generate Image (Lab)",
      "type": "shell",
      "command": "python",
      "args": ["scripts/generate_image_cli.py", "--lab", "${input:manaosImagePrompt}"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true },
      "group": "none"
    },
    {
      "label": "ManaOS: Generate Image (JP→EN)",
      "type": "shell",
      "command": "python",
      "args": ["scripts/generate_image_cli.py", "--jp", "${input:manaosImagePrompt}"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true },
      "group": "none"
    },
    {
      "label": "ManaOS: policy --list",
      "type": "shell",
      "command": "python",
      "args": ["${workspaceFolder}/tools/manaosctl.py", "policy", "--list"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "ManaOS: policy --check",
      "type": "shell",
      "command": "python",
      "args": ["${workspaceFolder}/tools/manaosctl.py", "policy", "--check"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared" }
    },
    {
      "label": "ManaOS: Control Panel 起動 (port 9800)",
      "type": "shell",
      "command": "python",
      "args": ["${workspaceFolder}/scripts/misc/manaos_dashboard_server.py"],
      "isBackground": true,
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "dedicated" }
    },
    {
      "label": "ManaOS: Control Panel を開く (ブラウザ)",
      "type": "shell",
      "command": "Start-Process",
      "args": ["http://127.0.0.1:9800/"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "silent", "panel": "shared" }
    },
    {
      "label": "ManaOS: daily report (stdout)",
      "type": "shell",
      "command": "python",
      "args": ["${workspaceFolder}/scripts/misc/manaos_daily_report.py", "--stdout"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared" }
    },

    // ─── manaosctl 運用タスク群 ──────────────────────────────
    {
      "label": "ManaOS: ① status（全サービス状態）",
      "type": "shell",
      "command": "python",
      "args": ["tools/manaosctl.py", "status"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true }
    },
    {
      "label": "ManaOS: ② up（Tier0+1 起動）",
      "type": "shell",
      "command": "python",
      "args": ["tools/manaosctl.py", "up"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true }
    },
    {
      "label": "ManaOS: ③ heal（DOWNを自動復旧）",
      "type": "shell",
      "command": "python",
      "args": ["tools/manaosctl.py", "heal"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true }
    },
    {
      "label": "ManaOS: ④ deps --order（起動順序確認）",
      "type": "shell",
      "command": "python",
      "args": ["tools/manaosctl.py", "deps", "--order"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true }
    },
    {
      "label": "ManaOS: ⑤ events（直近イベント30件）",
      "type": "shell",
      "command": "python",
      "args": ["tools/manaosctl.py", "events"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true }
    },
    {
      "label": "ManaOS: ⑥ analyze（LLMでイベント分析）",
      "type": "shell",
      "command": "python",
      "args": ["tools/manaosctl.py", "analyze"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true }
    },
    {
      "label": "ManaOS: ⑦ tier（Tier別サービス一覧）",
      "type": "shell",
      "command": "python",
      "args": ["tools/manaosctl.py", "tier"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true }
    },
    {
      "label": "ManaOS: heal --dry-run（復旧プレビュー）",
      "type": "shell",
      "command": "python",
      "args": ["tools/manaosctl.py", "heal", "--dry-run"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true }
    },
    {
      "label": "ManaOS: deps（全依存一覧）",
      "type": "shell",
      "command": "python",
      "args": ["tools/manaosctl.py", "deps"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true }
    },
    {
      "label": "ManaOS: deps --tree（blast-radius ツリー）",
      "type": "shell",
      "command": "python",
      "args": ["tools/manaosctl.py", "deps", "--tree"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true }
    },
    {
      "label": "ManaOS: watch --once（監視1回実行）",
      "type": "shell",
      "command": "python",
      "args": ["tools/manaosctl.py", "watch", "--once"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true }
    },
    {
      "label": "ManaOS: watch（60秒間隔 監視ループ）",
      "type": "shell",
      "command": "python",
      "args": ["tools/manaosctl.py", "watch"],
      "options": { "cwd": "${workspaceFolder}" },
      "problemMatcher": [],
      "presentation": { "reveal": "always", "panel": "shared", "echo": true }
    }
  ]
}
