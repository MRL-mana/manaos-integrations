ext","name":"text","type":"STRING","link":52}],"outputs":[{"localized_name":"文字列","name":"STRING","shape":6,"type":"STRING","links":[]}],"properties":{"cnr_id":"comfyui-custom-scripts","ver":"1.2.5","Node name for S&R":"ShowText|pysssss"},"widgets_values":["A highly detailed RAW photo captured with a Fujifilm XT5 and an 85mm f/1.8 lens, shot in 8k UHD, features a young woman with neat black short hair, smiling warmly at the camera from a three-quarter view as she looks over her shoulder. She wears a soft, pastel pink long-sleeved top with a subtle texture, and a delicate white frangipani flower is tucked behind her ear, adding a touch of natural charm. Her eyes are large and expressive, with visible natural skin texture, subtle pores, and realistic blush on her cheeks, conveying a gentle, joyful emotion. She stands beside a rustic wooden sign that reads “Good morning MORNING” in a clean, handwritten font, positioned at a slight angle in the foreground. The background is a sun-drenched garden with soft natural sunlight filtering through green trees and blooming yellow flowers, creating a shallow depth of field with creamy bokeh and atmospheric perspective. The overall lighting is cinematic and warm, evoking a peaceful, early morning atmosphere."]},{"id":38,"type":"ImageResizeKJv2","pos":[614.193958837547,-409.17636643265087],"size":[257.41604431152336,336],"flags":{},"order":10,"mode":0,"inputs":[{"localized_name":"image","name":"image","type":"IMAGE","link":44},{"localized_name":"mask","name":"mask","shape":7,"type":"MASK","link":null},{"localized_name":"width","name":"width","type":"INT","widget":{"name":"width"},"link":null},{"localized_name":"height","name":"height","type":"INT","widget":{"name":"height"},"link":null},{"localized_name":"upscale_method","name":"upscale_method","type":"COMBO","widget":{"name":"upscale_method"},"link":null},{"localized_name":"keep_proportion","name":"keep_proportion","type":"COMBO","widget":{"name":"keep_proportion"},"link":null},{"