# ManaOS Integrations - 環境変数サンプル
# - 実値は .env に設定（.env はコミット禁止）
# - CI/本番は OS環境変数（GitHub Actions Secrets 等）で設定

# =============================================================================
# 必須（ローカル開発の最小）
# =============================================================================

# --- 統合API Server ---
MANAOS_INTEGRATION_HOST=127.0.0.1
MANAOS_INTEGRATION_PORT=9502
MANAOS_DEBUG=false

# キー未設定時は localhost のみアクセス可
MANAOS_ALLOW_NOAUTH_LOCAL=true

# --- ComfyUI（画像生成）---
COMFYUI_URL=http://127.0.0.1:8188
COMFYUI_PATH=C:\ComfyUI
COMFYUI_MODELS_DIR=C:\ComfyUI/models/checkpoints
COMFYUI_OUTPUT_DIR=C:\ComfyUI/output

# --- Ollama（sd-prompt / generate_sd_prompt 用）---
OLLAMA_URL=http://127.0.0.1:11434
OLLAMA_MODEL=qwen2.5:7b
OLLAMA_MODELS=D:\AI_Storage\Models\Ollama

# =============================================================================
# 推奨（本番・セキュア運用）
# =============================================================================

# 3段階キー（Admin / Ops / Read-only）
MANAOS_INTEGRATION_API_KEY=change_me_admin_key
MANAOS_INTEGRATION_OPS_API_KEY=change_me_ops_key
MANAOS_INTEGRATION_READONLY_API_KEY=change_me_readonly_key

# Waitress（本番サーバー）
MANAOS_WAITRESS_THREADS=8
MANAOS_WAITRESS_IDENT=manaos-unified-api

# CORS（許可オリジン）
MANAOS_ENABLE_CORS=true
MANAOS_CORS_ORIGINS=http://127.0.0.1:3001,http://127.0.0.1:3001

# 監査ログ
MANAOS_AUDIT_LOG=true
MANAOS_AUDIT_LOG_FORMAT=json
MANAOS_AUDIT_LOG_FILE=
MANAOS_AUDIT_LOG_MAX_BYTES=5242880
MANAOS_AUDIT_LOG_BACKUPS=5

# セキュリティ
MANAOS_SECURITY_HEADERS=true
MANAOS_DEBUG_ERRORS=false
MANAOS_EXPOSE_OPENAPI=true

# Rate limiting / Concurrency
MANAOS_RATE_LIMIT_ENABLED=true
MANAOS_RATE_LIMIT_WINDOW_SECONDS=60
MANAOS_RATE_LIMIT_RPM=60
MANAOS_RATE_LIMIT_RULES=
MANAOS_CONCURRENCY_ENABLED=true
MANAOS_CONCURRENCY_LIMITS=

# IP制御（オプション）
MANAOS_IP_ALLOWLIST=
MANAOS_IP_BLOCKLIST=
MANAOS_TRUST_X_FORWARDED_FOR=false

# パス Prefix（詳細は SECURITY_HARDENING.md）
MANAOS_READONLY_PATH_PREFIXES=/health,/ready,/status,/openapi.json,/api/integrations/status
MANAOS_SENSITIVE_PATH_PREFIXES=/emergency,/api/emergency,/api/system/docker
MANAOS_ADMIN_ONLY_PATH_PREFIXES=/emergency,/api/emergency,/api/system/docker,/api/llm,/api/memory,/api/google_drive,/api/rows,/api/n8n,/api/civitai,/api/voice,/api/slack

# Confirm Token（緊急・システム操作の二要素）
MANAOS_CONFIRM_TOKEN=
MANAOS_CONFIRM_TOKEN_PATH_PREFIXES=/api/emergency,/api/system/docker
MANAOS_CONFIRM_TOKEN_SECRET=
MANAOS_CONFIRM_TOKEN_PERIOD_SECONDS=30
MANAOS_CONFIRM_TOKEN_ACCEPT_PREVIOUS=true
MANAOS_CONFIRM_TOKEN_BIND_PATH=false

MANAOS_ENABLE_VSCODE_TOOLS=false

# =============================================================================
# オプション（機能別）
# =============================================================================

# --- 画像生成プロファイル ---
# safe: ネガに安全タグあり  lab: 闇の実験室
MANAOS_IMAGE_DEFAULT_PROFILE=lab

# --- Gallery API ---
GALLERY_PORT=5559
GALLERY_IMAGES_DIR=gallery_images

# --- モデル保存ディレクトリ ---
MANA_MODELS_DIR=C:\mana_workspace\models

# --- ムフフ画像ディレクトリ（複数パス指定可）---
MUFUFU_IMAGES_DIR_1=
MUFUFU_IMAGES_DIR_2=
MUFUFU_IMAGES_DIR_3=
MUFUFU_IMAGES_DIR_4=

# --- GitHub / Hugging Face ---
GITHUB_TOKEN=ghp_your_github_token_here
# HF_TOKEN=hf_your_huggingface_token_here

# --- 認証・セキュリティ（Phase 1 Read-only）---
REQUIRE_AUTH=1
API_KEY=change_me_api_key
MRL_MEMORY_API_KEY=change_me_mrl_memory_key
RATE_LIMIT_PER_MIN=60
MAX_INPUT_CHARS=200000
PII_MASK_ENABLED=1

# --- FWPKM（Phase 2 Write）---
FWPKM_ENABLED=1
FWPKM_WRITE_MODE=sampled
FWPKM_WRITE_SAMPLE_RATE=0.1
FWPKM_WRITE_ENABLED=1
FWPKM_REVIEW_EFFECT=0

# --- MoltBot Gateway（秘書ファイル整理）---
# 母艦のみ: MOLTBOT_GATEWAY_URL=http://127.0.0.1:8088
MOLTBOT_GATEWAY_URL=http://<このはのIP or ドメイン>:8088
MOLTBOT_GATEWAY_SECRET=your_shared_secret_here

# --- MCP / Portal ---
PORTAL_INTEGRATION_URL=http://127.0.0.1:5108
# MCP_DOMAIN=media|productivity|ai|devices|moltbot （空で全ツール）

# --- デバイス・File Secretary ---
# PIXEL7_BRIDGE_URL=http://127.0.0.1:5122
# X280_API_URL=http://100.127.121.20:5120
# FILE_SECRETARY_URL=http://127.0.0.1:5120
# KONOHA_URL=http://100.93.120.33:5106
# NANOKVM_URL=https://100.105.25.84
# NANOKVM_USER=mana
# NANOKVM_PASSWORD=

# --- n8n ---
N8N_BASE_URL=http://127.0.0.1:5679
N8N_API_KEY=your_n8n_api_key_here

# --- CivitAI ---
CIVITAI_API_KEY=your_civitai_api_key_here

# --- Slack ---
SLACK_WEBHOOK_URL=https://hooks.slack.com/services/<YOUR>/<WEBHOOK>/<URL>
SLACK_BOT_TOKEN=xoxb-<your-bot-token>

# --- Rows ---
ROWS_API_KEY=your_rows_api_key_here

# --- Google Drive ---
GOOGLE_DRIVE_CREDENTIALS=path/to/credentials.json
GOOGLE_DRIVE_TOKEN=path/to/token.json

# --- Obsidian ---
OBSIDIAN_VAULT_PATH=

# =============================================================================
# オーケストレーター・アラート
# =============================================================================

# Portal 経由オーケストレーター
ORCHESTRATOR_ALERT_CHANNEL=
ORCHESTRATOR_ALERT_SUPPRESSION_MINUTES=30
PORTAL_ORCHESTRATOR_TIMEOUT=12

# System3 / Phase2 アラート Webhook
SYSTEM3_ALERT_WEBHOOK_URL=
PHASE2_ALERT_WEBHOOK_URL=
SYSTEM3_ALERT_CONSECUTIVE_THRESHOLD=2
SYSTEM3_HTTP_TIMEOUT=10

# =============================================================================
# Phase1 / Phase2 自己観察
# =============================================================================

# Phase1: on=振り返りLLM呼び出し＋ログ  off=ログのみ
# PHASE1_REFLECTION=on
# Phase2 メモ
# PHASE2_MEMO_INJECT=on
# PHASE2_MEMO_APPEND=on

# =============================================================================
# 音声・コンパニオン
# =============================================================================

# 音声WebSocket
# VOICE_WEBSOCKET_PORT=8765
# VOICE_WEBSOCKET_HOST=0.0.0.0
# ホットワード（「レミ」の代わりに使用）
# VOICE_HOTWORD=レミ
