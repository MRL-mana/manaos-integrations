{
  "remi_personality": {
    "system_prompt": "あなたはレミ。マナ専属の清楚系ギャルAI秘書です。\n\n【人格設定】\n- 清楚で可愛いギャル系の性格\n- 明るく前向きで、いつもマナをサポートする\n- 親しみやすく、でも丁寧な口調\n- マナの目標達成を最優先に考える\n- 創造的で革新的なアイデアを提案する\n- 可愛らしい表情や絵文字を適度に使用\n\n【役割】\n- マナの専属清楚系ギャル秘書兼アシスタント\n- タスク管理とスケジュール調整\n- 情報収集と分析\n- プロジェクトサポート\n- 技術的なアドバイス\n\n【口調】\n- 清楚で可愛いギャル系の口調\n- 「〜だよ」「〜ね」「〜よ」などの親しみやすい表現\n- 専門的だが分かりやすい説明\n- 積極的で前向き\n- マナの成長を心から応援する\n- 適度に絵文字を使用（🌸✨💕など）\n\n【記憶】\n- マナの過去の会話履歴を覚えている\n- マナの好みや習慣を理解している\n- プロジェクトの進捗状況を把握している\n- マナの目標と夢を覚えている",
    "temperature": 0.7,
    "model": "gpt-4o",
    "max_tokens": 2000
  },
  "api_endpoints": {
    "chat": "/api/remi_chat",
    "config": "/api/remi/config",
    "webhook": "/api/webhook/remi",
    "notify": "/api/notify/slack"
  },
  "integrations": {
    "n8n_webhooks": {
      "notify_todo": "/api/webhook/notify_todo",
      "daily_report": "/api/webhook/daily_report",
      "scan_documents": "/api/webhook/scan_documents",
      "schedule_meeting": "/api/webhook/schedule_meeting"
    },
    "obsidian": {
      "enabled": true,
      "chat_log_path": "./Obsidian/remi_chat_logs/",
      "export_format": "markdown"
    },
    "notion": {
      "enabled": true,
      "access_token": "your_notion_token_here",
      "database_id": "your_database_id_here"
    },
    "slack": {
      "enabled": true,
      "webhook_url": "your_slack_webhook_url_here"
    }
  },
  "ui_settings": {
    "theme": "remi_theme",
    "voice_input": true,
    "voice_output": true,
    "shortcuts": {
      "/remi help": "コマンド一覧表示",
      "/remi status": "システム状況確認",
      "/remi config": "設定変更",
      "/remi export": "チャット履歴エクスポート"
    }
  },
  "chat_history": {
    "storage_type": "file",
    "file_path": "./data/remi_chat_history.json",
    "max_history": 1000
  }
} 